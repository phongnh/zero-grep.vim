" autoload/zero_grep/filetype.vim - Filetype-aware rg/git grep helpers
" Maintainer: Phong Nguyen
"
" Fieltype args builder with rg -t / git grep -- glob filetype filtering.

" rg --type-list
let s:rg_filetypes = {
<% rg_filetypes.each do |filetype, extensions| -%>
            \ '<%= filetype %>': [<%= extensions.map { |ext| "'#{ext}'" }.join(", ") %>],
<% end -%>
            \ }

" Map vim filetype to rg filetype
" - key: vim filetype
" - value: rg filetype
let s:rg_filetype_mappings = {
            \ 'python':          'py',
            \ 'javascript':      'js',
            \ 'javascriptreact': 'js',
            \ 'typescript':      'ts',
            \ 'typescriptreact': 'ts',
            \ }

function! <%= namespace %>#RgFileTypeArgs(...) abort
    let l:ft = get(a:, 1, '')
    let l:ft = empty(l:ft) ? (&filetype !=# '' ? &filetype : &buftype) : l:ft
    let l:ft = get(s:rg_filetype_mappings, l:ft, l:ft)
    let l:args = []
    if !empty(l:ft) && has_key(s:rg_filetypes, l:ft)
        call add(l:args, '-t ' .. l:ft)
    else
        let l:ext = expand('%:e')
        if !empty(l:ext)
            call add(l:args, '-g ' .. shellescape(printf('*.{%s}', l:ext)))
        endif
    endif
    return l:args
endfunction

function! <%= namespace %>#GitFileTypeArgs(...) abort
    let l:ft = get(a:, 1, '')
    let l:ft = empty(l:ft) ? (&filetype !=# '' ? &filetype : &buftype) : l:ft
    let l:ft = get(s:rg_filetype_mappings, l:ft, l:ft)
    let l:args = []
    if !empty(l:ft) && has_key(s:rg_filetypes, l:ft)
        call add(l:args, '--')
        for l:ext in s:rg_filetypes[l:ft]
            call add(l:args, shellescape(l:ext))
        endfor
    else
        let l:ext = expand('%:e')
        if !empty(l:ext)
            call add(l:args, '--')
            call add(l:args, shellescape(printf('*.{%s}', l:ext)))
        endif
    endif
    return l:args
endfunction

function! s:detect_grep_tool(...) abort
    let l:tool = get(a:, 1, '')
    if l:tool ==# 'git' || stridx(getcmdprompt(), 'git') == 0 || stridx(&grepprg, 'git') == 0
        return 'git'
    endif
    return 'rg'
endfunction

function! <%= namespace %>#Args(...) abort
    let l:tool = get(a:, 1, '')
    let l:ft = get(a:, 2, '')
    if s:detect_grep_tool(l:tool) ==# 'git'
        return join(<%= namespace %>#GitFileTypeArgs(l:ft), ' ')
    else
        return join(<%= namespace %>#RgFileTypeArgs(l:ft), ' ')
    endif
endfunction
